# ==========================================
# EmailJS 設定 (環境變數範例檔)
# 請複製此檔案並命名為 .env，然後填入實際的金鑰
# 取得金鑰請至：https://www.emailjs.com/
# ==========================================

# 1. EmailJS 帳號通用設定
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ==========================================
# 2. 客戶端確認信範本 ID (發送給填表客戶)
# ==========================================

# 泛用客戶確認信範本 ID (工班預約與老屋翻新共用)
VITE_EMAILJS_TEMPLATE_ID=your_client_template_id

# ==========================================
# 3. 管理端通知設定 (發送給工作室內部)
# ==========================================

# 內部通知用的範本 ID (工班預約與老屋翻新共用)
VITE_EMAILJS_ADMIN_TEMPLATE_ID=your_admin_template_id

# 接收內部通知的 Email 地址 (例如工作室的管理信箱)
VITE_EMAILJS_ADMIN_EMAIL=admin@example.com
